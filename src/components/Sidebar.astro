---
import { getCollection } from 'astro:content';

const categories = [
	'Daily',
	'Project',
	'SQL',
	'Backend',
	'Frontend',
	'Python',
	'R',
	'Statistics',
	'Data-Science',
	'Computer-Science',
	'Book-Reading',
	'Cloud',
	'Algorithm',
];

const base = import.meta.env.BASE_URL;
const allPosts = await getCollection('blog');

const postsByCategory = categories.map((cat) => {
	const posts = allPosts
	.filter((post) => post.data.category === cat)
	.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
	return { name: cat, posts };
});
---

<nav class="sidebar">
	<a class="all-posts" href={`${base}blog`}>전체 글</a>
	<ul>
		{
			postsByCategory.map((cat) => (
				<li>
					<details>
						<summary>{cat.name}</summary>
						{cat.posts.length > 0 && (
							<ul class="posts">
								{cat.posts.map((post) => (
									<li>
										<a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
									</li>
								))}
							</ul>
						)}
					</details>
				</li>
			))
		}
	</ul>
</nav>

<style>
	.sidebar {
		width: 240px;
		flex-shrink: 0;
		padding: 1.5em 1em;
	}
	.all-posts {
		display: block;
		margin-bottom: 1em;
		padding: 0.4em 0.4em;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-weight: 700;
	}
	.all-posts:hover {
		color: rgb(var(--accent));
	}
	.sidebar > ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.sidebar > ul > li {
		margin-bottom: 0.2em;
	}
	summary {
		cursor: pointer;
		padding: 0.35em 0.4em;
		font-weight: 700;
		color: rgb(var(--black));
		border-radius: 6px;
		list-style: none;
	}
	summary::-webkit-details-marker {
		display: none;
	}
	summary::before {
		content: '▸';
		display: inline-block;
		width: 1em;
		color: rgb(var(--gray));
	}
	details[open] summary::before {
		content: '▾';
	}
	summary:hover {
		background-color: rgba(var(--accent), 0.08);
	}
	.posts {
		list-style: none;
		margin: 0.2em 0 0.4em 1.4em;
		padding: 0;
		border-left: 1px solid rgba(var(--gray), 0.3);
	}
	.posts li {
		margin: 0;
	}
	.posts a {
		display: block;
		padding: 0.3em 0.6em;
		font-size: 0.85rem;
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.posts a:hover {
		color: rgb(var(--accent));
		background-color: rgba(var(--accent), 0.06);
	}
</style>