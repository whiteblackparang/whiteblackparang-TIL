---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL;
---

<header>
	<nav>
		<h2><a href={base}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={base}>Home</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/whiteblackparang" target="_blank">GitHub</a>
			<a href="https://www.linkedin.com/in/jonghunlee/?locale=ko" target="_blank">LinkedIn</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		gap: 0.5em;
	}
	.social-links a {
		font-size: 0.9rem;
		font-weight: 500;
	}
</style>